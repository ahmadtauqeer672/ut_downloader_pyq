PORT=3000
ADMIN_UPLOAD_KEY=change_me

# Cloudinary (required for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pyq-papers

# PostgreSQL (required)
# For Neon: use the connection string from the Neon dashboard (General > Connection string),
# e.g. postgres://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_URL=postgres://user:password@host:5432/dbname
# Keep true for Neon and most cloud providers; set to false only if your provider says SSL is not needed
POSTGRES_SSL=true
